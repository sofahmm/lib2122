<Page x:Class="lib2122.Pages.AddReaderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:lib2122.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddReaderPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <TextBlock Text="Добавление читателя"
               Grid.Column="1"
               Grid.ColumnSpan="2"
               FontSize="38"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               FontWeight="Bold"/>
        <TextBlock Text="фамилия имя отчество"
               TextWrapping="Wrap"
               Grid.Column="0"
               Grid.Row="1"
               Grid.ColumnSpan="2"
               FontSize="25"
               HorizontalAlignment="Center"
               VerticalAlignment="Top"
               FontWeight="Bold"/>
        <TextBox Grid.Column="0"
             Grid.Row="1"
             Grid.ColumnSpan="2"
             VerticalAlignment="Bottom"
             Height="50"
             Width="300"
             Margin="0 0 0 20"
             Name="FioTb"
             FontSize="22"
             VerticalContentAlignment="Center"
             Padding="3 0 0 0"/>
        <TextBlock Text="дата рождения"
               Grid.Column="0"
               Grid.Row="2"
               Grid.ColumnSpan="2"
               FontSize="25"
               HorizontalAlignment="Center"
               VerticalAlignment="Top"
               FontWeight="Bold"/>
        <DatePicker Grid.Column="0"
             Grid.Row="2"
             Grid.ColumnSpan="2"
             VerticalAlignment="Bottom"
             Height="50"
             Width="300"
             Margin="0 0 0 20"
             Name="BirthDateDb"
             FontSize="22"
             VerticalContentAlignment="Center"
             Padding="3 0 0 0"/>
        <TextBlock Text="пол"
               Grid.Column="0"
               Grid.Row="3"
               Grid.ColumnSpan="2"
               FontSize="25"
               HorizontalAlignment="Center"
               VerticalAlignment="Top"
               FontWeight="Bold"/>
        <ComboBox Grid.Column="0"
              Grid.Row="3"
              Grid.ColumnSpan="2"
              VerticalAlignment="Bottom"
              Height="50"
              Width="300"
              Margin="0 0 0 20"
              Name="GenderCmb"
              VerticalContentAlignment="Center"
              Padding="3 0 0 0"
              ItemsSource="{Binding genders}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}"
                           FontSize="22"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <TextBlock Text="номер телефона"
               Grid.Column="2"
               Grid.Row="1"
               Grid.ColumnSpan="2"
               FontSize="25"
               HorizontalAlignment="Center"
               VerticalAlignment="Top"
               FontWeight="Bold"/>
        <TextBox Grid.Column="2"
             Grid.Row="1"
             Grid.ColumnSpan="2"
             VerticalAlignment="Bottom"
             Height="50"
             Width="300"
             Margin="0 0 0 20"
             Name="NumberPhoneTb"
             FontSize="22"
             VerticalContentAlignment="Center"
             Padding="3 0 0 0"/>
        <TextBlock Text="электронная почта"
               Grid.Column="2"
               Grid.Row="2"
               Grid.ColumnSpan="2"
               FontSize="25"
               HorizontalAlignment="Center"
               VerticalAlignment="Top"
               FontWeight="Bold"/>
        <TextBox Grid.Column="2"
             Grid.Row="2"
             Grid.ColumnSpan="2"
             VerticalAlignment="Bottom"
             Height="50"
             Width="300"
             Margin="0 0 0 20"
             Name="EmailTb"
             FontSize="22"
             VerticalContentAlignment="Center"
             Padding="3 0 0 0"/>
        <Button Name="SaveBtn"
            Click="SaveBtn_Click"
            Grid.Column="2"
            Grid.Row="3"
            Grid.ColumnSpan="2"
            Height="70"
            Width="200"
            FontSize="22"
            FontWeight="DemiBold"
            Foreground="DarkGreen"
            Background="DarkKhaki"
            Content="Сохранить"/>
    </Grid>
</Page>
